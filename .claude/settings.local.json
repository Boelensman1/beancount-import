{
  "permissions": {
    "allow": [
      "Bash(command make lint)",
      "Bash(npx prettier:*)",
      "Bash(command make test:*)"
    ],
    "deny": [],
    "ask": []
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "npx prettier --write ."
          }
        ]
      }
    ]
  }
}
