{
  "permissions": {
    "allow": [
      "Bash(make lint)",
      "Bash(pnpm exec prettier:*)",
      "Bash(make test:*)",
      "Bash(pnpm exec vitest:*)",
      "Bash(wc:*)",
      "Bash(ls:*)"
    ],
    "deny": ["Read(./data/**)"],
    "ask": []
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "pnpm exec prettier --write ."
          }
        ]
      }
    ]
  }
}
